# Copy to .env and adjust.
# Auto-loaded when a ".env" exists in the process working directory.
# To require a specific file path, set ENV_FILE=/path/to/other.env.

QDRANT_URL=http://localhost:6333
OLLAMA_URL=http://localhost:11434
LLM_MODEL=llama3
EMBED_MODEL=nomic-embed-text
QDRANT_COLLECTION=stock_facts
TOP_K=8
HTTP_TIMEOUT=30s
LISTEN_ADDR=:8080
# For containerized API service, use LISTEN_ADDR=0.0.0.0:8080.
