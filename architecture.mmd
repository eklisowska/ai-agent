%% AI Stock Analyst Agent — high-level HTTP and data flow.
%% Companion docs: README.md (quick start, env, layout), agentic_workflow_react.md (ReAct steps).
%% Requirements map (README): (1) data prep (2) RAG (3) reasoning & reflection (4) tools.
flowchart TD
    U[User / client]
    API[Go HTTP server]

    subgraph idx["Indexing — POST /index"]
        RAW["data/raw: profiles · financials · news"]
        PREP[Normalize to fact documents]
        Q[(Qdrant collection)]
        RAW --> PREP --> Q
    end

    subgraph react["ReAct — POST /analyze or POST /ask"]
        RET[Retrieve top-k by ticker]
        ACT[Act — tool signals]
        REASON[Reason — LLM pass 1]
        REFLECT[Reflect — LLM pass 2 + policy]
        RET --> ACT --> REASON --> REFLECT
    end

    OUT["JSON: RunResult"]

    U --> API
    API -->|POST /index| PREP
    Q --> RET
    REFLECT --> OUT
    API -->|POST /analyze · /ask| RET
